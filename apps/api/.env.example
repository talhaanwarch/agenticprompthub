# Copy to .env and fill in real values. Never commit .env.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agentichub
# Optional: maintenance DB used by `npm run db:setup` only to CREATE the app DB.
# Defaults to this value, so override only if your superuser/host differs.
# PG_ROOT_URL=postgres://postgres:postgres@localhost:5432/postgres
SESSION_SECRET=replace-with-output-of--openssl-rand-hex-32
NODE_ENV=development
PORT=3000
